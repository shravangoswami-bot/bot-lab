#!/usr/bin/env bash
set -euo pipefail

VERSION="0.2.0"
DESCRIPTION="Tiny local helper for GitHub bot account PRs."
AUTHOR="Shravan Goswami"
LICENSE="MIT"

export GH_CONFIG_DIR="${GH_CONFIG_DIR:-${XDG_CONFIG_HOME:-${HOME}/.config}/botlab/gh}"

PROG="$(basename "$0")"
BOT_OWNER="${BOT_OWNER:-shravangoswami-bot}"
BOT_EMAIL="${BOT_EMAIL:-shravangoswami-bot@users.noreply.github.com}"
COAUTHOR_NAME="${COAUTHOR_NAME:-shravanngoswamii}"
COAUTHOR_EMAIL="${COAUTHOR_EMAIL:-shravanngoswamii@users.noreply.github.com}"

usage() {
  cat <<USAGE
Usage:
  ${PROG} gh <gh args...>
  ${PROG} git <git args...>
  ${PROG} identity
  ${PROG} coauthor-hook
  ${PROG} install
  ${PROG} version

Examples:
  ${PROG} gh auth login
  ${PROG} gh auth status
  ${PROG} gh repo fork OWNER/REPO --clone=true
  ${PROG} identity
  ${PROG} coauthor-hook
  git add .
  git commit -m "Update files"
  ${PROG} git push origin branch-name

Environment:
  BOT_OWNER   Git commit author name. Default: shravangoswami-bot
  BOT_EMAIL   Git commit author email.
  GH_CONFIG_DIR Bot gh config directory. Default: ~/.config/botlab/gh
USAGE
}

die() {
  echo "error: $*" >&2
  exit 1
}

need() {
  command -v "$1" >/dev/null 2>&1 || die "$1 is required"
}

git_with_token() {
  local token
  token="$(gh auth token)"
  GITHUB_TOKEN="$token" git "$@"
}

set_identity() {
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "run this inside a git repo"
  git config user.name "$BOT_OWNER"
  git config user.email "$BOT_EMAIL"
  echo "Git identity set for this repo:"
  git config user.name
  git config user.email
}

install_self() {
  local bin_dir target source
  bin_dir="${HOME}/.local/bin"
  target="${bin_dir}/botlab"
  source="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")"

  mkdir -p "$bin_dir"
  ln -sf "$source" "$target"
  echo "Installed: ${target}"
  echo "If botlab is not found, add this to PATH: ${bin_dir}"
}

install_coauthor_hook() {
  local git_dir hook trailer
  git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "run this inside a git repo"

  git_dir="$(git rev-parse --git-dir)"
  hook="${git_dir}/hooks/prepare-commit-msg"
  trailer="Co-authored-by: ${COAUTHOR_NAME} <${COAUTHOR_EMAIL}>"

  if [ -f "$hook" ] && ! grep -q "botlab coauthor hook" "$hook"; then
    die "prepare-commit-msg hook already exists; merge this manually: ${hook}"
  fi

  cat >"$hook" <<EOF
#!/usr/bin/env bash
set -euo pipefail

# botlab coauthor hook
trailer='${trailer}'
msg_file="\$1"

if ! grep -Fqx "\${trailer}" "\${msg_file}"; then
  {
    printf '\\n'
    printf '%s\\n' "\${trailer}"
  } >>"\${msg_file}"
fi
EOF

  chmod +x "$hook"
  echo "Installed co-author hook: ${hook}"
  echo "${trailer}"
}

print_version() {
  cat <<VERSION_INFO
Name:        botlab
Version:     ${VERSION}
Description: ${DESCRIPTION}
Author:      ${AUTHOR}
License:     ${LICENSE}
VERSION_INFO
}

main() {
  local cmd="${1:-}"
  case "$cmd" in
    gh)
      need gh
      shift
      gh "$@"
      ;;
    git)
      need gh
      need git
      shift
      git_with_token "$@"
      ;;
    identity)
      need git
      set_identity
      ;;
    coauthor-hook)
      need git
      install_coauthor_hook
      ;;
    install)
      install_self
      ;;
    version|--version|-V)
      print_version
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      usage
      die "unknown command: $cmd"
      ;;
  esac
}

main "$@"
